# Required for cloud summaries. Leave empty when using Ollama.
GEMINI_API_KEY=
# Streamlit upload size in MB.
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=512
# 公開模式預設關閉伺服器本機路徑與資料夾批次功能。
MEETING_ALLOW_LOCAL_PATHS=0
# 只有在信任的內網環境才建議開啟自訂 Ollama URL。
MEETING_ALLOW_CUSTOM_OLLAMA=0
OLLAMA_BASE_URL=http://localhost:11434
